// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ApiKey {
  id          String   @id @default(cuid())
  shop        String   @unique
  encryptedKey String
  maskedKey   String
  balance     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ShopBillingState {
  id                 String   @id @default(cuid())
  shop               String   @unique
  activePlanSlug     String   @default("free")
  activePlanName     String?
  subscriptionId     String?
  subscriptionStatus String   @default("FREE")
  currentPeriodEnd   DateTime?
  isTest             Boolean  @default(false)
  lastSyncedAt       DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([subscriptionId])
}

model BillingCreditAllocation {
  id            String   @id @default(cuid())
  shop          String
  grantKey      String   @unique
  planSlug      String
  planName      String
  subscriptionId String
  credits       Int
  amountCents   Int
  currencyCode  String   @default("USD")
  periodEnd     DateTime?
  isTest        Boolean  @default(false)
  status        String   @default("pending")
  source        String?
  responseJson  String?
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shop, createdAt])
  @@index([shop, subscriptionId])
}

model ImaiJob {
  id          String   @id @default(cuid())
  jobId       String   @unique
  shop        String
  status      String   @default("queued") // queued, running, completed, failed
  endpoint    String   // "design" or "marketing"
  prompt      String
  imageUrl    String?
  result      String?  // JSON string of the result
  error       String?
  webhookDelivered Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([jobId])
  @@index([shop, status])
}
